{
  "info": {
    "name": "Toko Kelontong API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "item_id",
      "value": "1"
    },
    {
      "key": "cash_transaction_id",
      "value": "1"
